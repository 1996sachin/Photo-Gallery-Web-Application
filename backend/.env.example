DATABASE_URL=postgresql+asyncpg://sachin:password@localhost:5432/memoriesdb
SECRET_KEY=change-this-to-a-long-random-secret

# Backend URL used for verification links and Google OAuth callback.
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:8000

# Gmail SMTP. Use your Gmail address and a Google app password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USERNAME=your-gmail@gmail.com
SMTP_PASSWORD=your-google-app-password
SMTP_FROM=your-gmail@gmail.com

# Google OAuth. Add this redirect URI in Google Cloud:
# http://localhost:8000/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Minio Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=photo-gallery
MINIO_SECURE=False

# CDN Configuration (Cloudflare/CloudFront)
# Set USE_CDN=True to enable direct-to-cloud streaming/redirection
USE_CDN=False
# If using Cloudflare, this is your subdomain (e.g., memories.sachinsinghchaudhary.com.np)
CDN_DOMAIN=
